---
import "@splidejs/splide/dist/css/splide.min.css";
---

<section class="home-hero-wrap mt-[-24px] relative mb-[16px] md:mb-[0px]">
  <div class="one-hundred-bg hidden md:block" aria-hidden="true"></div>

  <div class="splide relative z-[2]" aria-label="My Splide" data-home-splide>
    <div class="splide__track">
      <ul class="splide__list">
        <li
          class="hidden md:block splide__slide w-[100%] mb-[12px] md:mb-[0px]"
        >
          <a
            href="/one-hundred"
            class="one-hundred-slide md:aspect-[4] lg:aspect-[7.5] flex px-[16px] justify-end items-end text-white text-wrap font-bold uppercase font-libre text-[32px] sm:text-[48px] lg:text-[48px] leading-[normal] relative"
          >
            <span class="z-[10] text-right">100 Years of The Triangle</span>
          </a>
        </li>

        <li class="splide__slide w-[100%] mb-[12px] md:mb-[0px]">
          <a class="block bg-[#acd4f4]" href="https://tr.ee/bqz8s-E4NK">
            <img
              src="/images/PodcastBanner.webp"
              class="w-full md:object-contain object-cover md:aspect-[4] lg:aspect-[7.5]"
            />
          </a>
        </li>

        <li class="splide__slide w-[100%] mb-[12px] md:mb-[0px]">
          <a class="block bg-[#E5E7EB]" href="/classifieds">
            <img
              src="/images/classifiedsBannerNew.webp"
              class="w-full md:object-contain object-cover md:aspect-[4] lg:aspect-[7.5]"
            />
          </a>
        </li>

        <li class="splide__slide w-[100%] mb-[12px] md:mb-[0px]">
          <a
            class="block bg-[#275997]"
            href="https://docs.google.com/forms/d/e/1FAIpQLScra_6sUenvmpIuQ5FjmMyWO0a2sz9z36HkrqfnYQvJGH9BGQ/viewform"
          >
            <img
              src="/images/applyBannerNew.webp"
              class="w-full md:object-contain object-cover md:aspect-[4] lg:aspect-[7.5]"
            />
          </a>
        </li>

        <!-- <li class="splide__slide w-[100%] mb-[12px] md:mb-[0px]">
          <a class="block bg-[#f3f592]" href="/graduation">
            <img
              src="/images/graduation-banner.webp"
              class="w-full md:object-contain object-cover object-bottom aspect-[5.5]"
            />
          </a>
        </li> -->
      </ul>
    </div>
  </div>
</section>

<script>
  import Splide from "@splidejs/splide";

  function initSplides() {
    document.querySelectorAll<HTMLElement>("[data-home-splide]").forEach((el) => {
      if (el.dataset.splideMounted === "true") return;

      el.dataset.splideMounted = "true";

      new Splide(el, {
        type: "loop",
        perPage: 1,
        autoplay: true,
        arrows: false,
        pagination: false,
        keyboard: false,
        drag: false,
        speed: 1200,
      }).mount();
    });
  }

  initSplides();

  document.addEventListener("astro:page-load", initSplides);
</script>
