---
import PhotoArticle from "../PhotoArticle.astro";
const { articles } = Astro.props
---
<div class="grid grid-cols-[1fr] md:grid-cols-[4fr_4fr] md:divide-x md:divide-triangleGray-400 ">
    <!-- Column 1: 2 blocks -->
    <div class="flex flex-col space-y-2 md:pr-[12px]">
        {articles.slice(0, 1).map(article => (
            <PhotoArticle title={article.title} 
            image={article.featured_image}
            author={article.authors}
            published_date={article.published_date}
            slug={"article/"+article.slug}/>
        ))}
    </div>

    <!-- Column 2: 1 block -->
    <div class="flex flex-col space-y-2 md:px-[12px]">
        {articles.slice(1, 5).map(article => (
            <PhotoArticle title={article.title}
            category={article.categories} 
            author={article.authors}
            published_date={article.published_date}
            slug={"article/"+article.slug}
        />
        ))}
    </div>
</div>
<div class="flex flex-col space-y-2">
    {articles.slice(5).map(article => (
        <PhotoArticle title={article.title} 
        category={article.categories}
        author={article.authors}
        published_date={article.published_date}
        slug={"article/"+article.slug}/>
    ))}
</div>