---
    import PhotoArticle from "./PhotoArticle.astro";
    const { articles } = Astro.props;
---
<div class="mb-[24px]">
    <div class="flex w-100 justify-between"><h1 class="font-roboto-slab uppercase font-extrabold"> Columns </h1> <a href="/columns" class="font-roboto-slab text-[14px] underline">See More &gt;</a></div>
    <div class="flex flex-col">
        {articles.map(article => (
            <PhotoArticle title={article.title} 
            category={article.categories}
            author={article.authors}
            published_date={article.published_date}
            slug={"article/"+article.slug}/>
        ))}
    </div>
</div>
