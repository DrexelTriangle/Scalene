---
export const prerender = false;
import Header from '../components/Header.astro';
import BaseLayout from "../layouts/BaseLayout.astro";
import '../styles/global.css';
---

<BaseLayout title="Page Not Found">
    <Header/>
    <section class="xl:max-w-[1200px] lg:max-w-[900px] max-w-[90%] mx-[auto] gap-[32px] h-[75vh] justify-center flex flex-wrap mt-[48px]">
        <img src="/images/marioTriangle.webp" class="w-[320px] aspect-[5/4] sm:w-[180px] sm:h-[230px] md:w-[200px] md:h-[250px] lg:w-[270px] lg:h-[300px]"/>
        <div class="w-[100%] sm:w-[50%] md:w-[50%] lg:w-[60%]">
            <h1 class="text-[42px] font-bold font-roboto-slab mb-2 text-wrap"> Sorry, we can't find what you're looking for. </h1>
            <form action="/search" method="GET">
                <input id="s" name="s" type="text" placeholder="Search" class="border-solid border-[1px] border-triangleBlue px-2 py-1 rounded-[10px] w-[80%] md:w-[300px] lg:w-[480px]"/>
                <button class="bg-triangleBlue text-white rounded-[10px] px-3 py-1"> ➤ </button>
            </form>
            <a href="/" class="text-[16px] mt-4 underline font-roboto-slab hover:text-triangleBlue block"> Return to homepage. </a>
        </div>
    </section>
</BaseLayout>