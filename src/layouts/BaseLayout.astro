---
import { ViewTransitions } from "astro:transitions";
import Footer from "../components/Footer.astro";
import Splash from "../components/Splash.astro";
import Matomo from "../components/Matomo.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = "https://www.thetriangle.org/logo.png",
  ogType = "website",
  noindex = false,
} = Astro.props;

const siteUrl = "https://www.thetriangle.org";
const pageUrl = canonical ?? siteUrl;

const websiteJSON = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "The Triangle",
  alternateName: ["Drexel Triangle", "The Drexel Triangle"],
  url: "https://www.thetriangle.org/",
  // SearchAction enables Google's Sitelinks Search Box in search results
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: "https://www.thetriangle.org/search?s={search_term_string}",
    },
    "query-input": "required name=search_term_string",
  },
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
     <link rel="me" href="https://github.com/Gilugali">

    <!-- Performance: preconnect to font and CMS origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://cms.thetriangle.org" />
    <link rel="dns-prefetch" href="https://stats.thetriangle.org" />
    <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />

    <!-- Open Graph -->
    <meta property="og:site_name" content="The Triangle" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@DrexelTriangle" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    <meta name="google-adsense-account" content="ca-pub-3937492883909624" />
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3937492883909624"
      crossorigin="anonymous"></script>

    <script type="text/javascript">
      (function (w, d, s, p) {
        const f = d.getElementsByTagName(s)[0],
          j = d.createElement(s);
        j.id = "flytedigital";
        j.async = true;
        j.src = "https://digital.flytedesk.com/js/head.js#" + p;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "prop_70U4oqbEQg0rQPaCMMuR");
    </script>

    <title>{title}</title>
    <Splash />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJSON)} />
    <!-- Extra head content from child layouts (e.g. article JSON-LD) -->
    <slot name="head" />
    <ViewTransitions />
  </head>
  <body class="w-100 min-h-screen flex flex-col">
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <Matomo />
  </body>
</html>
