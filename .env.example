# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Gmail account used to send guest-post submission emails (src/pages/api/guest.ts).
# PASS must be a Gmail "App Password" if 2FA is enabled on the account.
EMAIL=
PASS=

# Slack incoming webhook URLs for the contact / tipline / classifieds forms.
SLACK_WEBHOOK=
SLACK_WEBHOOK_TIPS=
SLACK_WEBHOOK_CLASSIFIEDS=

# Matomo analytics site id / instance.
MATOMO=

# Canonical site origin (e.g. https://www.thetriangle.org).
SITE_ORIGIN=
